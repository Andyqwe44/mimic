{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri/config.schema.json",
  "productName": "Game Agent Monitor",
  "version": "0.1.0",
  "identifier": "com.andyqwe44.game-agent-monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Game Agent Monitor",
        "width": 1280,
        "height": 720,
        "minWidth": 324,
        "minHeight": 216,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
