// Game Agent Monitor — MAA-inspired (Slint v1.17)
import { Button, VerticalBox, HorizontalBox, LineEdit, ScrollView } from "std-widgets.slint";

global Theme {
    out property <color> bg: #1C1C1C;
    out property <color> card-bg: #252528;
    out property <color> accent: #326CF3;
    out property <color> text: #E6E6E6;
    out property <color> text-secondary: #A0A0A0;
    out property <color> text-dim: #606060;
    out property <color> success: #60D060;
    out property <color> error: #FF6666;
    out property <color> border: #3A3A3D;
}

component BtnPrimary {
    in property <string> label; callback clicked();
    min-width: 120px; min-height: 32px;
    Rectangle { background: Theme.accent; border-radius: 4px;
        HorizontalLayout { padding-left: 16px; padding-right: 16px;
            Text { text: root.label; font-size: 13px; color: white; horizontal-alignment: center; }
        }
        TouchArea { clicked => { root.clicked(); } }
    }
}
component BtnDanger {
    in property <string> label; callback clicked();
    min-width: 120px; min-height: 32px;
    Rectangle { background: Theme.error; border-radius: 4px;
        HorizontalLayout { padding-left: 16px; padding-right: 16px;
            Text { text: root.label; font-size: 13px; color: white; horizontal-alignment: center; }
        }
        TouchArea { clicked => { root.clicked(); } }
    }
}
component BtnOutline {
    in property <string> label; callback clicked();
    min-width: 120px; min-height: 32px;
    Rectangle { border-width: 1px; border-color: Theme.border; border-radius: 4px; background: transparent;
        HorizontalLayout { padding-left: 16px; padding-right: 16px;
            Text { text: root.label; font-size: 13px; color: Theme.text-secondary; horizontal-alignment: center; }
        }
        TouchArea { clicked => { root.clicked(); } }
    }
}
component Card {
    in property <string> title;
    Rectangle { background: Theme.card-bg; border-radius: 6px;
        VerticalLayout { padding: 16px; spacing: 10px;
            if root.title != "" : Text { text: root.title; font-size: 15px; font-weight: 600; color: Theme.text; }
            @children
        }
    }
}
component TabBtn {
    in property <string> label;
    in property <bool> active;
    callback clicked();
    min-width: 90px; min-height: 44px;
    HorizontalLayout { padding-left: 14px; padding-right: 14px;
        Text { text: root.label; font-size: 14px; color: root.active ? Theme.accent : Theme.text-secondary; font-weight: root.active ? 600 : 400; }
    }
    if root.active : Rectangle { y: parent.height - 2px; width: 100%; height: 2px; background: Theme.accent; }
    TouchArea { clicked => { root.clicked(); } }
}

// ═══ Monitor ═══
export component MonitorPage {
    in property <string> task-name: "TicTacToe";
    in property <bool> running;
    in property <string> resolution: "---";
    callback start(); callback stop(); callback screenshot(); callback click();

    VerticalLayout { padding: 24px; spacing: 16px;
        Rectangle { background: Theme.card-bg; border-radius: 6px; min-height: 52px;
            HorizontalLayout { padding-left: 16px; padding-right: 16px; spacing: 16px;
                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: root.running ? Theme.success : Theme.text-dim; }
                Text { text: root.running ? "Task Running" : "Idle"; font-size: 15px; font-weight: 600; color: Theme.text; }
                Rectangle { width: 1px; background: Theme.border; }
                Text { text: root.task-name; font-size: 13px; color: Theme.text-secondary; }
                Text { text: root.resolution; font-size: 13px; color: Theme.text-dim; }
                Rectangle { }
                if !root.running : BtnPrimary { label: "Start"; clicked => { root.start(); } }
                if root.running : BtnDanger { label: "Stop"; clicked => { root.stop(); } }
            }
        }
        HorizontalLayout { spacing: 16px;
            Rectangle { background: Theme.card-bg; border-radius: 6px;
                VerticalLayout { padding: 40px;
                    Text { text: "Game View"; font-size: 14px; color: Theme.text-dim; horizontal-alignment: center; }
                    Text { text: root.running ? "Live capture active" : "Start task"; font-size: 12px; color: Theme.text-dim; horizontal-alignment: center; }
                }
            }
            Rectangle { min-width: 260px;
                VerticalLayout { spacing: 12px;
                    Card { title: "Tools";
                        VerticalLayout { spacing: 8px;
                            HorizontalLayout { spacing: 8px;
                                BtnOutline { label: "Screenshot"; clicked => { root.screenshot(); } }
                                BtnOutline { label: "Test Click"; clicked => { root.click(); } }
                            }
                        }
                    }
                    Card { title: "Info";
                        Text { text: "Game: " + root.task-name; font-size: 13px; color: Theme.text-secondary; }
                        Text { text: "Resolution: " + root.resolution; font-size: 13px; color: Theme.text-secondary; }
                    }
                }
            }
        }
    }
}

// ═══ Log ═══
export component LogPage {
    in property <string> log-text: "";
    VerticalLayout { padding: 24px; spacing: 12px;
        HorizontalLayout { spacing: 12px;
            Text { text: "Operation Log"; font-size: 15px; font-weight: 600; color: Theme.text; }
            BtnOutline { label: "Clear"; }
        }
        Rectangle { background: Theme.card-bg; border-radius: 6px;
            ScrollView {
                Text { text: root.log-text == "" ? "No events yet." : root.log-text; font-size: 12px; color: Theme.text-secondary; font-family: "Consolas,monospace"; wrap: word-wrap; }
            }
        }
    }
}

// ═══ Config ═══
export component ConfigPage {
    in-out property <string> game-window: "Tic Tac Toe";
    in-out property <string> server-host: "127.0.0.1";
    in-out property <string> server-port: "9999";
    ScrollView {
        VerticalLayout { padding: 24px; spacing: 16px;
            Card { title: "Game Window";
                Text { text: "Title of the game window to capture."; font-size: 13px; color: Theme.text-dim; }
                HorizontalLayout { spacing: 12px;
                    Text { text: "Window Title"; font-size: 14px; color: Theme.text-secondary; vertical-alignment: center; min-width: 100px; }
                    LineEdit { text <=> root.game-window; }
                }
            }
            Card { title: "Model Server";
                Text { text: "AI model server connection."; font-size: 13px; color: Theme.text-dim; }
                HorizontalLayout { spacing: 12px;
                    Text { text: "Host"; font-size: 14px; color: Theme.text-secondary; vertical-alignment: center; min-width: 100px; }
                    LineEdit { text <=> root.server-host; }
                }
                HorizontalLayout { spacing: 12px;
                    Text { text: "Port"; font-size: 14px; color: Theme.text-secondary; vertical-alignment: center; min-width: 100px; }
                    LineEdit { text <=> root.server-port; }
                }
            }
        }
    }
}

// ═══ Settings ═══
export component SettingsPage {
    in property <string> version: "v0.1.0";
    ScrollView {
        VerticalLayout { padding: 24px; spacing: 16px;
            Card { title: "About";
                Text { text: "Game Agent Monitor"; font-size: 15px; font-weight: 600; color: Theme.text; }
                Text { text: "Version: " + root.version; font-size: 13px; color: Theme.text-secondary; }
                Text { text: "Author: Andyqwe44"; font-size: 13px; color: Theme.text-secondary; }
                Text { text: "Universal game-playing AI agent."; font-size: 12px; color: Theme.text-dim; }
            }
            Card { title: "Project";
                Text { text: "github.com/Andyqwe44/tictactoe"; font-size: 13px; color: Theme.accent; }
                BtnPrimary { label: "Star on GitHub"; }
            }
        }
    }
}

// ═══ Main Window ═══
export component AppWindow inherits Window {
    title: "Game Agent Monitor";
    preferred-width: 1100px; preferred-height: 700px;
    min-width: 800px; min-height: 500px;

    in property <string> version: "v0.1.0";
    in-out property <int> page: 0;
    in property <bool> running: false;
    in property <string> status: "Idle";
    in property <string> log-text: "";
    in property <float> fps: 0.0;
    in property <float> latency: 0.0;
    in property <string> resolution: "---";
    callback start(); callback stop(); callback screenshot(); callback click();

    background: Theme.bg;
    VerticalLayout { spacing: 0px;
        // Tab bar
        Rectangle { background: Theme.card-bg; min-height: 44px;
            HorizontalLayout { spacing: 0px; padding-left: 12px; padding-right: 12px;
                TabBtn { label: "Monitor";  active: root.page == 0; clicked => { root.page = 0; } }
                TabBtn { label: "Log";      active: root.page == 1; clicked => { root.page = 1; } }
                TabBtn { label: "Config";   active: root.page == 2; clicked => { root.page = 2; } }
                TabBtn { label: "Settings"; active: root.page == 3; clicked => { root.page = 3; } }
                Rectangle { }
                Text { text: root.version; font-size: 11px; color: Theme.text-dim; }
            }
        }
        // Pages
        if root.page == 0 : MonitorPage { running: root.running; resolution: root.resolution; start => { root.start(); } stop => { root.stop(); } screenshot => { root.screenshot(); } click => { root.click(); } }
        if root.page == 1 : LogPage { log-text: root.log-text; }
        if root.page == 2 : ConfigPage {}
        if root.page == 3 : SettingsPage { version: root.version; }
        // Status bar
        Rectangle { background: Theme.card-bg; min-height: 28px;
            HorizontalLayout { spacing: 16px; padding-left: 12px; padding-right: 12px;
                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: root.running ? Theme.success : Theme.text-dim; }
                Text { text: root.status; font-size: 11px; color: Theme.text-dim; }
                Text { text: "| FPS: " + round(root.fps) + " | Lat: " + round(root.latency) + "ms | github.com/Andyqwe44/tictactoe"; font-size: 11px; color: Theme.text-dim; }
            }
        }
    }
}
